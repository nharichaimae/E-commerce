<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ category.name }} - Our Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
    <!-- Header -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
        <div class="container">
            <a class="navbar-brand" href="{{ path('products') }}">Our Store</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('products') }}">Products</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('cart') }}">Cart</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <!-- Breadcrumb -->
    <div class="container mt-4">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('products') }}" class="text-decoration-none">Home</a></li>
                <li class="breadcrumb-item"><a href="{{ path('categories') }}" class="text-decoration-none">Categories</a></li>
                <li class="breadcrumb-item active" aria-current="page">{{ category.name }}</li>
            </ol>
        </nav>
    </div>

    <!-- Jumbotron -->
    <div class="container my-4">
        <div class="p-5 mb-4 bg-primary bg-gradient text-white rounded-3">
            <div class="container-fluid py-3">
                        <h1>{{ category.name }}</h1>
                <p class="col-md-8 fs-5">{{ category.description ?? 'Discover the latest products in this category.' }}</p>
                <span class="badge bg-light text-dark fs-6">{{ products|length }} Products Available</span>
            </div>
        </div>
    </div>

    <!-- Products by Category -->
    <div class="container mb-5">
        <div class="row mb-4">
            <div class="col">
                <div class="d-flex justify-content-between align-items-center">
                    <h3>Browse {{ category.name }}</h3>
                    <div class="btn-group" role="group">
                        <button type="button" class="btn btn-outline-secondary active">Grid</button>
                        <button type="button" class="btn btn-outline-secondary">List</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="row row-cols-1 row-cols-md-3 g-4">
            {% for product in products %}
            <div class="col">
                <div class="card h-100">
                <img src="{{ asset('mouse.png') }}" class="card-img-top" alt="Produit">
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">{{ product.category.name }}</span>
                        <h5 class="card-title">{{ product.name }}</h5>
                        <p class="card-text fw-bold text-success">${{ product.price }}</p>
                        <a href="{{ path('product_details', {'id': product.id}) }}" class="btn btn-outline-primary">View Details</a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>

        <!-- Pagination -->
        <nav aria-label="Product pagination" class="mt-5">
            <ul class="pagination justify-content-center">
                <li class="page-item disabled">
                    <a class="page-link" href="#" tabindex="-1">Previous</a>
                </li>
                <li class="page-item active"><a class="page-link" href="#">1</a></li>
                <li class="page-item"><a class="page-link" href="#">2</a></li>
                <li class="page-item"><a class="page-link" href="#">3</a></li>
                <li class="page-item">
                    <a class="page-link" href="#">Next</a>
                </li>
            </ul>
        </nav>
    </div>

    <!-- Footer -->
    <footer class="bg-dark text-white mt-5 py-4">
        <div class="container">
            <div class="row">
                <div class="col-md-6">
                    <h5>Our Store</h5>
                    <p>Quality products at affordable prices</p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p>&copy; 2026 Our Store. All rights reserved.</p>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>